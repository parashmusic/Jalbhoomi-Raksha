# ─── BhumiRaksha Environment Configuration ───────────────────────────

# App
APP_NAME=BhumiRaksha
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-secure-random-string

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql+asyncpg://bhumiraksha:password@localhost:5432/bhumiraksha
DATABASE_URL_SYNC=postgresql://bhumiraksha:password@localhost:5432/bhumiraksha

# Redis (image hash storage + caching)
REDIS_URL=redis://localhost:6379/0

# Google Earth Engine
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=./keys/gee-service-key.json

# ML Models
YOLO_MODEL_PATH=./models/flood_yolov8m.pt
SEGFORMER_MODEL_PATH=./models/segformer_b4_flood.pth

# SMS Provider (MSG91 / Twilio)
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=BRAKSH
MSG91_TEMPLATE_ID=your-template-id
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890

# PFMS (Public Financial Management System)
PFMS_API_URL=https://pfms.nic.in/api/v1
PFMS_API_KEY=your-pfms-api-key
PFMS_AGENCY_CODE=your-agency-code

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Officer Authentication
OFFICER_JWT_SECRET=change-me-officer-jwt-secret
OFFICER_JWT_EXPIRY_HOURS=24
